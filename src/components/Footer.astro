---
/* Footer — stacked wordmark, context line, three info columns
   (Socials / Email / Set in), baseline row.
   Spec note for pre-launch: spot-check the TikTok and Threads handles on
   each platform in case of squatting. */
const socials = [
  { name: "Instagram", href: "https://instagram.com/allstarsteven" },
  { name: "Facebook", href: "https://facebook.com/allstarsteven" },
  { name: "TikTok", href: "https://tiktok.com/@allstarsteven" },
  { name: "YouTube", href: "https://youtube.com/@allstarsteven" },
  { name: "Threads", href: "https://threads.net/@allstarsteven" },
];
---

<footer class="footer">
  <div class="wrap">
    <p class="footer__mark">allstar<br />steven</p>
    <p class="footer__context">Based in NYC, mostly thinking about Japan.</p>

    <div class="footer__cols">
      <div class="footer__col">
        <p class="footer__label">Socials</p>
        <ul class="footer__list">
          {
            socials.map((s) => (
              <li>
                <a href={s.href} target="_blank" rel="noopener noreferrer">
                  {s.name} — @allstarsteven
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="footer__col">
        <p class="footer__label">Email</p>
        <ul class="footer__list">
          <li><a href="mailto:welfmgmt@gmail.com">welfmgmt@gmail.com</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <p class="footer__label">Set in</p>
        <ul class="footer__list">
          <li>Space Grotesk</li>
          <li>Inter</li>
          <li>IBM Plex Mono</li>
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <span>© 2026 allstarsteven</span>
      <span>One person, a few projects</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--ink);
    padding-block: 24px 28px;
  }

  .footer__mark {
    margin-bottom: 18px;
    font-family: var(--display);
    font-weight: 700;
    font-size: 52px;
    line-height: 0.95;
    letter-spacing: -0.045em;
  }
  .footer__context {
    margin-bottom: 20px;
    max-width: 280px;
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 500;
    line-height: 1.6;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-65);
  }

  .footer__cols {
    display: grid;
    grid-template-columns: 1fr;
    gap: 22px;
  }
  .footer__label {
    margin-bottom: 8px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--concrete-2);
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-65);
  }
  .footer__list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    line-height: 1.5;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .footer__list a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    margin-top: 24px;
    padding-top: 16px;
    border-top: 1px solid var(--concrete-2);
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-65);
  }

  @media (min-width: 1200px) {
    .footer {
      padding-block: 44px 36px;
    }
    .footer__mark {
      margin-bottom: 18px;
      font-size: 104px;
      line-height: 0.88;
      letter-spacing: -0.055em;
    }
    .footer__context {
      margin-bottom: 40px;
      max-width: 440px;
      font-size: 12px;
      letter-spacing: 0.16em;
    }
    .footer__cols {
      grid-template-columns: repeat(3, 1fr);
      gap: 32px;
    }
    .footer__label {
      margin-bottom: 12px;
      padding-bottom: 12px;
      font-size: 11px;
      letter-spacing: 0.18em;
    }
    .footer__list {
      font-size: 13px;
      line-height: 1.7;
    }
    .footer__bottom {
      margin-top: 56px;
      padding-top: 22px;
      font-size: 11px;
      letter-spacing: 0.16em;
    }
  }
</style>
