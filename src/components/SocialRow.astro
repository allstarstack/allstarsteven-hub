---
/* Social links — monospace text labels, no icons.
   Handles are placeholders (spec items list — confirm post-build).
   YouTube omitted until the handle is confirmed. */
const socials = [
  { label: "Instagram", href: "https://instagram.com/allstarsteven" },
  { label: "TikTok", href: "https://tiktok.com/@allstarsteven" },
];
---

<nav class="socials" aria-label="Social links">
  {
    socials.map((s) => (
      <a
        class="socials__link"
        href={s.href}
        target="_blank"
        rel="noopener noreferrer"
      >
        {s.label}
      </a>
    ))
  }
</nav>

<style>
  .socials {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
  }
  .socials__link {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink-70);
    text-decoration: none;
  }
  .socials__link:hover {
    color: var(--ink-black);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
