---
/* Header strip — ■ ALLSTARSTEVEN · HUB · 02 PROPERTIES (V4 spec).
   The ■ is a CSS block, not a glyph. Uppercasing is done in CSS. */
---

<header class="topbar">
  <div class="wrap topbar__inner">
    <span class="topbar__brand">AllstarSteven</span>
    <span class="topbar__hub">Hub</span>
    <span class="topbar__count">02 properties</span>
  </div>
</header>

<style>
  .topbar__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 12px;
    padding-block: 14px;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .topbar__brand {
    justify-self: start;
    display: inline-flex;
    align-items: center;
  }
  .topbar__brand::before {
    content: "";
    width: 10px;
    height: 10px;
    margin-right: 9px;
    background: var(--ink);
  }
  .topbar__hub {
    justify-self: center;
  }
  .topbar__count {
    justify-self: end;
    color: var(--ink-65);
  }

  @media (min-width: 1200px) {
    .topbar__inner {
      padding-block: 22px;
      font-size: 12px;
      letter-spacing: 0.16em;
    }
    .topbar__brand::before {
      width: 12px;
      height: 12px;
      margin-right: 12px;
    }
  }
</style>
